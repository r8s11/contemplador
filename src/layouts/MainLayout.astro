---
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../constants";
import "../styles/colors.css";

const { title = "" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta name="description" content={SITE_DESCRIPTION} />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{SITE_TITLE} 🤔 {title}</title>

    <!-- Google Fonts — Fraunces (display), Newsreader (body), Caveat (hand) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600;700&family=Fraunces:ital,opsz,wght@0,9..144,100..900;1,9..144,100..900&family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="bg-light font-body text-primary min-h-screen flex flex-col relative"
  >
    <!-- Grain texture overlay -->
    <div class="grain-overlay" aria-hidden="true"></div>

    <Nav currentPath={currentPath} />
    <main class="container mx-auto max-w-screen-xl mt-10 px-6 sm:px-8 flex-1">
      <slot />
    </main>
    <Footer />
    <!-- Start of HubSpot Embed Code -->
    <script
      is:inline
      type="text/javascript"
      id="hs-script-loader"
      async
      defer
      src="//js-na2.hs-scripts.com/243485944.js"></script>
    <!-- End of HubSpot Embed Code -->
  </body>
</html>

<style is:global>
  /* ——— Base ——— */
  body {
    font-family: "Newsreader", Georgia, serif;
    font-optical-sizing: auto;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  /* ——— Grain texture for paper feel ——— */
  .grain-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 200px;
  }

  /* ——— Stagger animation delays ——— */
  .stagger-1 {
    animation-delay: 0.1s;
  }
  .stagger-2 {
    animation-delay: 0.2s;
  }
  .stagger-3 {
    animation-delay: 0.3s;
  }
  .stagger-4 {
    animation-delay: 0.4s;
  }
  .stagger-5 {
    animation-delay: 0.5s;
  }
  .stagger-6 {
    animation-delay: 0.6s;
  }

  /* ——— Display font helper ——— */
  .font-display {
    font-family: "Fraunces", Georgia, serif;
    font-optical-sizing: auto;
  }

  /* ——— Handwritten font helper ——— */
  .font-hand {
    font-family: "Caveat", cursive;
  }

  /* ——— Decorative ink underline ——— */
  .ink-underline {
    position: relative;
    display: inline-block;
  }
  .ink-underline::after {
    content: "";
    position: absolute;
    left: -4%;
    bottom: -2px;
    width: 108%;
    height: 8px;
    background: rgb(217 131 36 / 0.25);
    border-radius: 40% 60% 50% 40%;
    z-index: -1;
    transform: rotate(-0.5deg);
  }

  /* ——— Warm link style ——— */
  a.warm-link {
    color: rgb(3 71 72);
    text-decoration: none;
    background-image: linear-gradient(
      rgb(217 131 36 / 0.3),
      rgb(217 131 36 / 0.3)
    );
    background-size: 100% 2px;
    background-position: 0 100%;
    background-repeat: no-repeat;
    transition: background-size 0.3s ease;
  }
  a.warm-link:hover {
    background-size: 100% 100%;
  }

  /* ——— Prose / article body ——— */
  .prose {
    font-family: "Newsreader", Georgia, serif;
    font-optical-sizing: auto;
    color: rgb(61 54 42);
  }

  .prose p {
    margin: 1.4em 0;
    line-height: 1.85;
    font-size: 1.1rem;
  }

  .prose h2 {
    font-family: "Fraunces", Georgia, serif;
    margin: 2.5em 0 0.75em;
    font-size: 1.85rem;
    font-weight: 600;
    line-height: 1.25;
    color: rgb(0 16 33);
  }

  .prose h3 {
    font-family: "Fraunces", Georgia, serif;
    margin: 2em 0 0.5em;
    font-size: 1.4rem;
    font-weight: 500;
    line-height: 1.35;
    color: rgb(0 16 33);
  }

  .prose ul,
  .prose ol {
    margin: 1.25em 0;
    padding-left: 1.5em;
  }

  .prose li {
    margin: 0.6em 0;
    line-height: 1.75;
  }

  .prose blockquote {
    border-left: 3px solid rgb(217 131 36);
    padding: 1em 1.5em;
    margin: 2em 0;
    background: rgb(248 230 211 / 0.25);
    border-radius: 0 12px 12px 0;
    font-style: italic;
    font-size: 1.15rem;
    color: rgb(99 90 72);
    position: relative;
  }

  .prose blockquote::before {
    content: "\201C";
    font-family: "Fraunces", serif;
    font-size: 4rem;
    position: absolute;
    top: -8px;
    left: 12px;
    color: rgb(217 131 36 / 0.2);
    line-height: 1;
  }

  .prose code {
    background: rgb(237 230 216);
    padding: 0.2em 0.45em;
    border-radius: 4px;
    font-size: 0.88em;
    color: rgb(3 71 72);
  }

  .prose pre {
    background: rgb(0 16 33);
    color: rgb(214 231 254);
    padding: 1.5em;
    border-radius: 12px;
    overflow-x: auto;
    margin: 2em 0;
    line-height: 1.65;
    border: 1px solid rgb(0 16 33 / 0.1);
    box-shadow: 0 8px 32px rgb(0 16 33 / 0.15);
  }

  .prose pre code {
    background: transparent;
    padding: 0;
    font-size: 0.875em;
    color: inherit;
  }

  .prose a {
    color: rgb(3 71 72);
    text-decoration: underline;
    text-decoration-color: rgb(217 131 36 / 0.4);
    text-underline-offset: 3px;
    text-decoration-thickness: 2px;
    transition: all 0.2s ease;
  }

  .prose a:hover {
    text-decoration-color: rgb(217 131 36);
    color: rgb(217 131 36);
  }

  .prose img {
    border-radius: 12px;
    margin: 2em 0;
    box-shadow: 0 4px 24px rgb(0 16 33 / 0.08);
  }

  .prose hr {
    border: none;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgb(217 131 36 / 0.3) 20%,
      rgb(217 131 36 / 0.3) 80%,
      transparent
    );
    margin: 3em 0;
  }

  /* ——— Smooth scrolling ——— */
  html {
    scroll-behavior: smooth;
  }

  /* ——— Selection ——— */
  ::selection {
    background: rgb(217 131 36 / 0.2);
    color: rgb(0 16 33);
  }

  /* ——— Margin decoration for article pages ——— */
  .margin-note {
    font-family: "Caveat", cursive;
    color: rgb(176 164 142);
    font-size: 1.1rem;
    transform: rotate(-2deg);
  }
</style>
