---
import type { CollectionEntry } from "astro:content";
import { formatDate } from "../utils";
import Tags from "./Tags.astro";

const { article } = Astro.props;

interface Props {
  article: CollectionEntry<"blog">;
}
---

<article
  class="group bg-light rounded-2xl overflow-hidden border border-light-200 hover:border-accent/25 transition-all duration-400 hover:-translate-y-1 hover:shadow-xl flex flex-col"
>
  <!-- Accent top edge -->
  <div
    class="h-0.5 bg-gradient-to-r from-transparent via-accent/40 to-transparent group-hover:via-accent transition-all duration-500"
  >
  </div>

  <div class="p-6 flex flex-col flex-1">
    <div class="flex-1">
      <p class="text-light-500 mb-3 font-hand text-base">
        {formatDate(article.data.pubDate)}
      </p>
      <h2 class="font-display text-xl font-bold mb-3 text-primary leading-snug">
        <a
          href={"/articles/" + article.slug}
          class="hover:text-accent transition-colors duration-300"
        >
          {article.data.title}
        </a>
      </h2>
    </div>

    <div class="mt-4 pt-4 border-t border-accent/10">
      <Tags tags={article.data.tags} />
    </div>
  </div>

  <!-- Read more -->
  <a
    href={"/articles/" + article.slug}
    class="block px-6 py-3 border-t border-accent/10 text-accent font-display text-sm text-center group-hover:bg-accent/5 transition-all duration-300"
  >
    Read article <span class="font-hand text-base">→</span>
  </a>
</article>
