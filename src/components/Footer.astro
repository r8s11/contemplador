---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import { capitalize } from "../utils";

// Filter out draft articles
const allBlogArticles: CollectionEntry<"blog">[] = await getCollection(
  "blog",
  (entry) => {
    return !entry.data.title.startsWith("Draft");
  },
);

const tags: string[] = allBlogArticles.flatMap((article) => article.data.tags);
const uniqueTags: string[] = [...new Set(tags)];
---

<footer class="bg-primary text-light mt-16">
  <!-- Decorative top border -->
  <div
    class="h-px bg-gradient-to-r from-transparent via-accent/40 to-transparent"
  >
  </div>

  <div class="container mx-auto max-w-screen-xl px-6 sm:px-8 py-12">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand / About -->
      <div class="lg:col-span-2">
        <a href="/" class="inline-flex items-center gap-2 mb-4 group">
          <span class="text-accent text-xl">🤔</span>
          <span
            class="font-hand text-3xl text-light-50 group-hover:text-accent transition-colors duration-300"
          >
            El Contemplador
          </span>
        </a>
        <p class="text-light-300 text-sm leading-relaxed max-w-md">
          Roosevelt Segura's digital sanctuary where web development meets
          personal reflection. A space for sharing technical insights, life
          lessons, and the evolving landscape of modern web technologies.
        </p>
        <p class="text-light-500 mt-4 font-hand text-base">
          Father · Developer · Dancer · Thinker
        </p>
      </div>

      <!-- Categories -->
      <div>
        <h3
          class="font-display text-sm font-semibold mb-4 text-light-200 uppercase tracking-wider"
        >
          Categories
        </h3>
        <ul class="space-y-2.5">
          {
            uniqueTags.map((tag) => (
              <li>
                <a
                  href={`/articles/tag/${tag}`}
                  class="text-light-300 text-sm hover:text-accent-700 transition-colors duration-200 inline-flex items-center gap-1.5"
                >
                  <span class="text-accent-600 text-xs">#</span>
                  {capitalize(tag)}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h3
          class="font-display text-sm font-semibold mb-4 text-light-200 uppercase tracking-wider"
        >
          Connect
        </h3>
        <ul class="space-y-2.5">
          <li>
            <a
              href="mailto:roosevelt@contemplador.dev"
              class="text-light-300 text-sm hover:text-accent-700 transition-colors duration-200 inline-flex items-center gap-2"
            >
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
              Email
            </a>
          </li>
          <li>
            <a
              href="https://www.linkedin.com/in/rooseveltsegura"
              target="_blank"
              rel="noopener noreferrer"
              class="text-light-300 text-sm hover:text-accent-700 transition-colors duration-200 inline-flex items-center gap-2"
            >
              <svg
                class="w-4 h-4"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                ></path>
              </svg>
              LinkedIn
            </a>
          </li>
          <li>
            <a
              href="https://x.com/r8s11"
              target="_blank"
              rel="noopener noreferrer"
              class="text-light-300 text-sm hover:text-accent-700 transition-colors duration-200 inline-flex items-center gap-2"
            >
              <svg
                class="w-4 h-4"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                ></path>
              </svg>
              Twitter / X
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Copyright -->
  <div class="border-t border-light/10">
    <div class="container mx-auto max-w-screen-xl px-6 sm:px-8 py-4">
      <p class="text-center text-xs text-light-500">
        © {new Date().getFullYear()} Roosevelt Segura · Made with
        <span class="text-accent">♥</span> and curiosity
      </p>
    </div>
  </div>
</footer>
