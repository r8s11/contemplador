---

---

<form
  id="search-form"
  class="flex items-center gap-2"
  action="/articles/search"
>
  <label for="query" class="sr-only">Search</label>
  <div class="relative flex-1">
    <div
      class="absolute inset-y-0 left-0 flex items-center pl-3.5 pointer-events-none"
    >
      <svg
        class="w-4 h-4 text-light-500"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 20 20"
      >
        <path
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="m19 19-4-4m0-7A7 7 0 1 1 1 8a7 7 0 0 1 14 0Z"></path>
      </svg>
    </div>
    <input
      type="text"
      id="query"
      name="query"
      class="bg-light border border-accent/15 text-primary font-body text-sm rounded-xl focus:ring-2 focus:ring-accent/20 focus:border-accent/40 block w-full pl-10 pr-4 py-3 placeholder-light-500 transition-all duration-300"
      placeholder="Search contemplations..."
      required
    />
  </div>
  <button
    type="submit"
    class="px-5 py-3 text-sm font-display font-medium text-light bg-accent rounded-xl hover:bg-accent-400 focus:ring-4 focus:outline-none focus:ring-accent/20 transition-all duration-300 shadow-sm hover:shadow-md"
  >
    Search
  </button>
</form>
