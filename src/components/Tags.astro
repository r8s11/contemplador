---
const { tags } = Astro.props;

interface Props {
  tags: string[];
}
---

<div class="flex flex-wrap gap-2">
  {
    tags.map((tag) => (
      <a
        href={`/articles/tag/${tag}`}
        class="px-3 py-1 bg-accent/10 text-accent rounded-full text-xs font-display font-medium hover:bg-accent/20 border border-accent/15 hover:border-accent/30 transition-all duration-300"
      >
        #{tag}
      </a>
    ))
  }
</div>
