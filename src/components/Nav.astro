---
import { getCollection } from "astro:content";
import { capitalize } from "../utils";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

// Filter out draft articles
const allBlogArticles = await getCollection("blog", (entry) => {
  return !entry.data.title.startsWith("Draft");
});

const tags = allBlogArticles.flatMap((article) => article.data.tags);
const uniqueTags = [...new Set(tags)];

const isActive = (path: string) => {
  if (path === "/") return currentPath === "/";
  return currentPath.startsWith(path);
};
---

<nav class="sticky top-0 z-50 border-b border-accent/10" id="main-nav">
  <div class="absolute inset-0 bg-light/90 backdrop-blur-md"></div>
  <div
    class="relative max-w-screen-xl flex flex-wrap items-center justify-between mx-auto px-6 py-4"
  >
    <!-- Logo / wordmark -->
    <a href="/" class="flex items-center gap-3 group">
      <span
        class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-accent text-lg shadow-md group-hover:shadow-lg transition-shadow duration-300"
      >
        🤔
      </span>
      <span
        class="font-hand text-3xl sm:text-4xl text-primary group-hover:text-accent transition-colors duration-300"
      >
        El Contemplador
      </span>
    </a>

    <!-- Mobile toggle -->
    <button
      data-collapse-toggle="navbar-default"
      type="button"
      class="inline-flex items-center p-2 w-10 h-10 justify-center text-primary rounded-lg md:hidden hover:bg-accent/10 focus:outline-none focus:ring-2 focus:ring-accent/30 transition-colors duration-200"
      aria-controls="navbar-default"
      aria-expanded="false"
    >
      <span class="sr-only">Open main menu</span>
      <svg
        class="w-5 h-5"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 17 14"
      >
        <path
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M1 1h15M1 7h15M1 13h15"></path>
      </svg>
    </button>

    <!-- Nav links -->
    <div class="hidden w-full md:block md:w-auto" id="navbar-default">
      <ul
        class="flex flex-col p-4 md:p-0 mt-4 rounded-lg md:flex-row md:items-center md:gap-1 md:mt-0"
      >
        <li>
          <a
            href="/"
            class:list={[
              "nav-link block py-2 px-4 rounded-lg font-display text-sm tracking-wide transition-all duration-200",
              isActive("/")
                ? "text-accent font-semibold"
                : "text-light-700 hover:text-accent",
            ]}
            aria-current={isActive("/") ? "page" : undefined}
          >
            Home
            {
              isActive("/") && (
                <span class="block h-0.5 bg-accent rounded-full mt-0.5 animate-draw-line origin-left" />
              )
            }
          </a>
        </li>
        <li>
          <a
            href="/articles"
            class:list={[
              "nav-link block py-2 px-4 rounded-lg font-display text-sm tracking-wide transition-all duration-200",
              isActive("/articles")
                ? "text-accent font-semibold"
                : "text-light-700 hover:text-accent",
            ]}
          >
            Articles
            {
              isActive("/articles") && (
                <span class="block h-0.5 bg-accent rounded-full mt-0.5 animate-draw-line origin-left" />
              )
            }
          </a>
        </li>

        <!-- Categories Dropdown -->
        <li class="relative group">
          <button
            class="nav-link flex items-center py-2 px-4 rounded-lg font-display text-sm tracking-wide text-light-700 hover:text-accent transition-all duration-200"
          >
            Categories
            <svg
              class="w-3.5 h-3.5 ml-1.5 transition-transform duration-300 group-hover:rotate-180"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>

          <div
            class="absolute left-0 mt-2 w-56 bg-light border border-accent/10 rounded-2xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50 overflow-hidden"
          >
            <div class="p-2">
              {
                uniqueTags.slice(0, 8).map((tag) => (
                  <a
                    href={`/articles/tag/${tag}`}
                    class="flex items-center gap-2 px-4 py-2.5 text-sm text-light-700 hover:bg-accent/8 hover:text-accent rounded-xl transition-all duration-200"
                  >
                    <span class="font-hand text-accent text-base">#</span>
                    <span class="font-display text-sm">{capitalize(tag)}</span>
                  </a>
                ))
              }
            </div>
          </div>
        </li>

        <li>
          <a
            href="/about"
            class:list={[
              "nav-link block py-2 px-4 rounded-lg font-display text-sm tracking-wide transition-all duration-200",
              isActive("/about")
                ? "text-accent font-semibold"
                : "text-light-700 hover:text-accent",
            ]}
          >
            About
            {
              isActive("/about") && (
                <span class="block h-0.5 bg-accent rounded-full mt-0.5 animate-draw-line origin-left" />
              )
            }
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<style>
  .nav-link {
    position: relative;
  }
  .nav-link::after {
    content: "";
    position: absolute;
    bottom: 4px;
    left: 16px;
    right: 16px;
    height: 2px;
    background: rgb(217 131 36);
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }
  .nav-link:hover::after {
    transform: scaleX(1);
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const btn = document.querySelector(
      '[data-collapse-toggle="navbar-default"]',
    );
    const menu = document.getElementById("navbar-default");
    if (btn && menu) {
      btn.addEventListener("click", () => {
        menu.classList.toggle("hidden");
      });
    }
  });
</script>
